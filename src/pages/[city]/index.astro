---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Explorer from '../../components/Explorer.tsx';
import { computeCity, rankWithWeights } from '../../lib/scoring';
import { getDistricts, METRICS } from '../../data/districts';
import { CITIES, getCity } from '../../data/cities';
import { getEnvironment, getEmployment, getGreenery } from '../../data/environment';
import { getCityStats } from '../../data/cityStats';
import { SITE } from '../../consts';

export function getStaticPaths() {
  return CITIES.map((c) => ({ params: { city: c.key } }));
}

const city = getCity(Astro.params.city!)!;
const districts = computeCity(getDistricts(city.key));
const ranked = rankWithWeights(districts);
const top = ranked[0];
const env = getEnvironment(city.key);
const emp = getEmployment(city.key);
const green = getGreenery(city.key);
const stats = getCityStats(city.key);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${city.name}区县宜居度`,
  url: new URL(`/${city.key}/`, Astro.site).href,
  description: SITE.description,
  inLanguage: SITE.locale,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: ranked.length,
    itemListElement: ranked.slice(0, 5).map((r, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${r.district.name}（${r.grade} 级）`,
      url: new URL(`/${city.key}/district/${r.district.adcode}`, Astro.site).href,
    })),
  },
};
---

<BaseLayout
  title={`${city.name}区县宜居度对比`}
  description={`${city.name}${districts.length} 个区县六维宜居度对比：经济、人口、教育、医疗、交通、生活。人口与配套为真实公开数据，可自定义权重实时重排。`}
  path={`/${city.key}/`}
  jsonLd={jsonLd}
>
  <section class="container-page py-10 sm:py-14">
    <div class="mx-auto max-w-3xl text-center">
      <span class="rounded-full bg-accent-soft px-3 py-1 text-xs font-medium text-accent">
        🏙️ {city.name} · {districts.length} 区县 · 六维评分
      </span>
      <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-5xl">
        {city.name} {districts.length} 区，<span class="text-accent">哪个最适合你</span>？
      </h1>
      <p class="mt-4 text-base text-ink-soft sm:text-lg">
        经济、人口、教育、医疗、交通、生活 六维横向对比。拖动权重，地图与排行榜实时重排。
      </p>
    </div>

    <div class="mx-auto mt-8 grid max-w-2xl grid-cols-3 gap-3 text-center">
      <div class="card p-4">
        <div class="text-2xl font-bold text-accent">{districts.length}</div>
        <div class="text-xs text-ink-soft">区县全覆盖</div>
      </div>
      <div class="card p-4">
        <div class="text-2xl font-bold text-accent">{METRICS.length}</div>
        <div class="text-xs text-ink-soft">评分维度</div>
      </div>
      <div class="card p-4">
        <div class="text-2xl font-bold text-accent">自定义</div>
        <div class="text-xs text-ink-soft">权重实时重排</div>
      </div>
    </div>

    {env && (
      <div class="mx-auto mt-4 max-w-2xl rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
        🌿 {city.name}{env.year}年环境：PM2.5 年均 <strong>{env.pm25} μg/m³</strong>，AQI 优良率 <strong>{env.aqiGoodRate}%</strong>
        {env.pm10 && `，PM10 ${env.pm10} μg/m³`}
        <span class="text-xs text-emerald-600">（市级数据，来源：<a href={env.sourceUrl} class="underline">{env.source}</a>）</span>
      </div>
    )}

    {emp && (
      <div class="mx-auto mt-2 max-w-2xl rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-800">
        💼 {city.name}{emp.year}年就业：城镇新增 <strong>{emp.newJobs} 万人</strong>
        {emp.surveyUnemploymentRate && `，调查失业率 <strong>${emp.surveyUnemploymentRate}%</strong>`}
        <span class="text-xs text-blue-600">（市级数据，来源：<a href={emp.sourceUrl} class="underline">{emp.source}</a>）</span>
      </div>
    )}

    {green && (
      <div class="mx-auto mt-2 max-w-2xl rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
        🌳 {city.name}{green.year}年绿化：
        {green.perCapitaParkArea && `人均公园绿地 <strong>${green.perCapitaParkArea} ㎡</strong>`}
        {green.parkCount && `，公园 <strong>${green.parkCount} 座</strong>`}
        {green.perCapitaSportsArea && `，人均体育场地 ${green.perCapitaSportsArea} ㎡`}
        <span class="text-xs text-green-600">（市级数据，来源：<a href={green.sourceUrl} class="underline">{green.source}</a>）</span>
      </div>
    )}

    {stats && (
      <div class="mx-auto mt-4 max-w-2xl">
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
          {stats.gdp && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.gdp.toLocaleString()}亿</div>
              <div class="text-[10px] text-ink-soft">GDP ({stats.year})</div>
            </div>
          )}
          {stats.perCapitaGdp && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{(stats.perCapitaGdp / 10000).toFixed(1)}万</div>
              <div class="text-[10px] text-ink-soft">人均GDP (元)</div>
            </div>
          )}
          {stats.urbanDisposableIncome && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.urbanDisposableIncome.toLocaleString()}</div>
              <div class="text-[10px] text-ink-soft">城镇人均收入 (元)</div>
            </div>
          )}
          {stats.ruralDisposableIncome && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.ruralDisposableIncome.toLocaleString()}</div>
              <div class="text-[10px] text-ink-soft">农村人均收入 (元)</div>
            </div>
          )}
          {stats.perCapitaConsumption && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.perCapitaConsumption.toLocaleString()}</div>
              <div class="text-[10px] text-ink-soft">人均消费 (元)</div>
            </div>
          )}
        </div>
        <div class="mt-2 grid grid-cols-2 gap-2 sm:grid-cols-4">
          {stats.metroLines && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.metroLines}条/{stats.metroKm}km</div>
              <div class="text-[10px] text-ink-soft">轨道交通 ({stats.metroStations}站)</div>
            </div>
          )}
          {stats.universities && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.universities}</div>
              <div class="text-[10px] text-ink-soft">普通高校 (所)</div>
            </div>
          )}
          {stats.healthInstitutions && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.healthInstitutions.toLocaleString()}</div>
              <div class="text-[10px] text-ink-soft">卫生机构 (个)</div>
            </div>
          )}
          {stats.hospitals && (
            <div class="card p-3 text-center">
              <div class="text-lg font-bold text-accent">{stats.hospitals}</div>
              <div class="text-[10px] text-ink-soft">医院 (个)</div>
            </div>
          )}
        </div>
        {stats.newHousePriceIndex && (
          <p class="mt-2 text-center text-xs text-ink-soft">
            📈 {stats.year}年房价指数：新建住宅 <strong>{stats.newHousePriceIndex}</strong>，二手住宅 <strong>{stats.secondHandPriceIndex}</strong>（上年=100）
          </p>
        )}
      </div>
    )}

    <div class="mt-10">
      <Explorer client:load districts={districts} citySlug={city.key} />
    </div>

    {
      top && (
        <p class="mt-6 text-center text-sm text-ink-soft">
          默认均权下，综合宜居度第一：
          <a href={`/${city.key}/district/${top.district.adcode}`} class="font-semibold text-accent hover:underline">
            {top.district.name}
          </a>
          （{top.grade} 级，{top.composite.toFixed(0)} 分）
        </p>
      )
    }
  </section>

  <section class="container-page pb-16">
    <h2 class="text-xl font-bold">六大评分维度</h2>
    <p class="mt-1 text-sm text-ink-soft">
      每个维度独立打分，可点开看原始数据与来源 —— 详见
      <a href="/methodology" class="text-accent hover:underline">评分方法</a>。
    </p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        METRICS.map((m) => (
          <a
            href={`/${city.key}/rankings/${m.key}`}
            class="card group block p-5 transition hover:-translate-y-0.5 hover:shadow-lg"
          >
            <div class="flex items-center justify-between">
              <h3 class="font-semibold">
                {m.label}
                {!m.real && <span class="ml-1 text-[10px] text-ink-soft">示例</span>}
              </h3>
              <span class="text-xs text-ink-soft transition group-hover:text-accent">排行 →</span>
            </div>
            <p class="mt-2 text-sm text-ink-soft">{m.description}</p>
            <p class="mt-2 text-xs text-ink-soft">单位：{m.unit} · 来源：{m.source}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
